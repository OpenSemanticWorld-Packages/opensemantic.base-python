# PostgREST integration test configuration
# Copy to .env and fill in values to enable PostgREST tests.
# Tests are skipped unless both TEST_PGRST_URL and TEST_PGRST_JWT_SECRET are set.

# PostgREST base URL
TEST_PGRST_URL=http://localhost:3000

# JWT secret used to sign tokens (must match PGRST_JWT_SECRET in docker-compose)
TEST_PGRST_JWT_SECRET=reallyreallyreallyreallyverysafe

# JWT role claim (default: api_user)
# TEST_PGRST_JWT_ROLE=api_user

# PostgREST schema (default: api)
# TEST_PGRST_SCHEMA=api
